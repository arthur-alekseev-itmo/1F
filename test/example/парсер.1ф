пусть п_символ предикат вход =
  сопоставить вход с
  | [] -> ошибка "Конец файла" []
  | г :: х когда предикат г -> вернуть г х
  | _ -> ошибка "Символ не удовлетворяет предикату" []
в

пусть элемент список элем =
  сопоставить список с
  | [] -> нет
  | г :: х когда г = элем -> да
  | г :: х -> элемент х элем
в

